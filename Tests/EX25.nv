print("=== Fibonacci Correct Test ===")

fun fib(n) {
    if (n <= 1) {
        return n
    }
    var a = 0
    var b = 1
    loop (i = 0; i < n; i = i + 1) {
        var temp = a + b
        a = b
        b = temp
    }
    return a
}

print("fib(0) =", fib(0))
print("fib(1) =", fib(1))
print("fib(2) =", fib(2))
print("fib(3) =", fib(3))
print("fib(4) =", fib(4))
print("fib(5) =", fib(5))
print("fib(6) =", fib(6))
print("fib(7) =", fib(7))
print("fib(8) =", fib(8))
print("fib(9) =", fib(9))
print("fib(10) =", fib(10))